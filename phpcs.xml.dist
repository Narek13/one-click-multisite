<?xml version="1.0"?>
<ruleset name="One Click Multisite">
    <description>WordPress Coding Standards for One Click Multisite plugin.</description>

    <arg name="colors"/>
    <arg value="sp"/>
    <arg name="extensions" value="php"/>

    <file>./src</file>
    <file>./one-click-multisite.php</file>
    <file>./tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- WordPress ruleset -->
    <rule ref="WordPress"/>
    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>

    <!-- Enforce that all global functions/variables/constants are prefixed -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="one_click_multisite"/>
                <element value="OneClickMultisite"/>
                <element value="ocm"/>
            </property>
        </properties>
    </rule>

    <!-- Enforce text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="one-click-multisite"/>
            </property>
        </properties>
    </rule>

    <!-- PHP version compatibility -->
    <config name="testVersion" value="7.4-"/>
    <config name="minimum_supported_wp_version" value="6.0"/>

    <!-- Allow short array syntax -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- OOP code: allow camelCase method names inside classes -->
    <rule ref="WordPress.NamingConventions.ValidFunctionName">
        <exclude-pattern>src/*</exclude-pattern>
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <!-- Type hints and strict declarations are intentional -->
    <rule ref="Squiz.Commenting.FunctionComment.MissingParamComment">
        <severity>0</severity>
    </rule>
</ruleset>
